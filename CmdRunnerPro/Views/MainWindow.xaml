
<Window x:Class="CmdRunnerPro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CmdRunnerPro"
        xmlns:utils="clr-namespace:CmdRunnerPro.Utilities"
        Title="CMD Runner Pro" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Save Settings" Click="SaveSettings_Click"/>
                <Separator/>
                <MenuItem Header="_Export">
                    <MenuItem Header="_Templates..." Click="ExportTemplates_Click"/>
                    <MenuItem Header="_Presets (no passwords)..." Click="ExportPresets_Click"/>
                    <MenuItem Header="Presets (include _encrypted passwords)..." Click="ExportPresetsWithPw_Click"/>
                    <MenuItem Header="_Sequences..." Click="ExportSequences_Click"/>
                </MenuItem>
                <MenuItem Header="_Import">
                    <MenuItem Header="_Templates..." Click="ImportTemplates_Click"/>
                    <MenuItem Header="_Presets..." Click="ImportPresets_Click"/>
                    <MenuItem Header="_Sequences..." Click="ImportSequences_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Templates..." Click="Templates_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Log File Location" Click="ShowLog_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <!-- Left pane scrolls: give it a minimum width so controls don't collapse -->
                <ColumnDefinition Width="3*" MinWidth="300"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <!-- Top row contains the three panes -->
                <RowDefinition Height="Auto"/>
                <!-- Bottom row is the output with most of the height -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- LEFT: Inputs & Presets (SCROLLABLE) -->
            <ScrollViewer Grid.Column="0" Grid.Row="0" Margin="0,0,10,10"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
                <StackPanel>
                    <TextBlock Text="Working Directory" FontWeight="Bold"/>
                    <DockPanel>
                        <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" MinWidth="260"/>
                        <Button Content="Browse" Margin="5,0,0,0" Click="Browse_Click"/>
                        <Button Content="Open" Margin="5,0,0,0" Click="OpenWD_Click"/>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Button Content="Auto-Detect WD" Click="AutoDetectWD_Click" Margin="0,0,5,0"/>
                        <Button Content="Test MeterMate" Click="TestMeterMate_Click"/>
                    </StackPanel>

                    <TextBlock Text="COM Port 1" FontWeight="Bold" Margin="0,10,0,0"/>
                    <ComboBox ItemsSource="{Binding AvailablePorts}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Name"
                      SelectedValue="{Binding SelectedCom1}">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="IsEnabled"
                                Value="{Binding InUse, Converter={StaticResource InverseBoolConverter}}"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <TextBlock Text="COM Port 2" FontWeight="Bold" Margin="0,10,0,0"/>
                    <ComboBox ItemsSource="{Binding AvailablePorts}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Name"
                      SelectedValue="{Binding SelectedCom2}">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="IsEnabled"
                                Value="{Binding InUse, Converter={StaticResource InverseBoolConverter}}"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <TextBlock Text="Username" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding Username}" MinWidth="260"/>

                    <TextBlock Text="Password (masked + encrypted at rest)" FontWeight="Bold" Margin="0,10,0,0"/>
                    <PasswordBox
                xmlns:utils="clr-namespace:CmdRunnerPro.Utilities"
                utils:PasswordBoxHelper.BindPassword="True"
                utils:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="OpCo" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding Opco}" MinWidth="260"/>

                    <TextBlock Text="Program" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding Program}" MinWidth="260"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Refresh Ports" Click="RefreshPorts_Click"/>
                    </StackPanel>

                    <Separator Margin="0,10,0,10"/>
                    <TextBlock Text="Input Presets" FontWeight="Bold"/>
                    <DockPanel>
                        <ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}" Width="200"/>
                        <Button Content="Load" Margin="5,0,0,0" Click="LoadPreset_Click"/>
                    </DockPanel>
                    <DockPanel Margin="0,5,0,0">
                        <TextBox x:Name="PresetNameBox" Width="200"/>
                        <Button Content="Save Preset" Margin="5,0,0,0" Click="SavePreset_Click"/>
                    </DockPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- MIDDLE: Templates -->
            <Grid Grid.Column="1" Grid.Row="0" Margin="0,0,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <GroupBox Header="Command Templates" Grid.Row="0">
                    <ListBox ItemsSource="{Binding Templates}"
                     SelectedItem="{Binding SelectedTemplate}"
                     DisplayMemberPath="Name"
                     MouseDoubleClick="Templates_DoubleClick"/>
                </GroupBox>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                    <Button Content="Add To Queue"
                    Click="AddToQueue_Click"
                    IsEnabled="{Binding SelectedTemplate, Converter={StaticResource NullToBoolConverter}}"/>
                </StackPanel>
            </Grid>

            <!-- RIGHT: Queue & Run -->
            <Grid Grid.Column="2" Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <GroupBox Header="Queue" Grid.Row="0">
                    <DockPanel>
                        <ListBox x:Name="QueueList" ItemsSource="{Binding Queue}">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Move Up" Click="Up_Click"/>
                                    <MenuItem Header="Move Down" Click="Down_Click"/>
                                    <MenuItem Header="Remove" Click="Remove_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Clear" Click="Clear_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                    </DockPanel>
                </GroupBox>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,6">
                    <Button Content="Up" Margin="5" Click="Up_Click"/>
                    <Button Content="Down" Margin="5" Click="Down_Click"/>
                    <Button Content="Remove" Margin="5" Click="Remove_Click"/>
                    <Button Content="Clear" Margin="5" Click="Clear_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <CheckBox Content="Stop on error" IsChecked="{Binding StopOnError}" Margin="0,0,10,0"/>
                    <Button Content="Run" Margin="5" Click="Run_Click" IsEnabled="{Binding CanRun}"/>
                    <Button Content="Stop" Margin="5" Click="Stop_Click" IsEnabled="{Binding IsRunning}"/>
                    <TextBlock Text="{Binding LogFile}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- BOTTOM: Output (live) -->
            <GroupBox Grid.Row="1" Grid.ColumnSpan="3" Header="Output (live)">
                <ScrollViewer x:Name="OutputScroll" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding OutputLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock x:Name="LineText" FontFamily="Consolas" Text="{Binding Line}"/>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                        <Setter TargetName="LineText" Property="Foreground" Value="Crimson"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
